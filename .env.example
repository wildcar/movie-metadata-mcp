# -------------------------------------------------------------------
# movie-metadata-mcp — example environment file.
# Copy to .env and fill in real values. Never commit .env.
# -------------------------------------------------------------------

# --- Upstream providers --------------------------------------------

# TMDB API Read Access Token (v4 auth), NOT the v3 API key.
# How to obtain:
#   1. Sign up / log in at https://www.themoviedb.org/
#   2. Go to Settings → API (https://www.themoviedb.org/settings/api)
#   3. Request a Developer key (free; a one-line "personal" justification is
#      enough for a read-only aggregator).
#   4. On the resulting page copy the "API Read Access Token" (long JWT-like
#      string starting with "eyJ..."). That is the v4 token this server uses.
TMDB_API_TOKEN=

# OMDb API key (free tier: 1000 req/day).
# How to obtain:
#   1. Go to https://www.omdbapi.com/apikey.aspx
#   2. Pick the FREE tier, enter an email address.
#   3. Confirm via the email you receive; the key is printed in that email.
OMDB_API_KEY=

# kinopoisk.dev API token (unofficial Кинопоиск API).
# How to obtain:
#   1. Open Telegram and message @kinopoiskdev_bot.
#   2. Use /api to request a key. The free tier (200 req/day) is enough for dev.
#   3. Save the token the bot sends you.
# Docs: https://kinopoisk.dev/documentation
KINOPOISK_DEV_TOKEN=

# --- Caching --------------------------------------------------------

# Path to the SQLite file used as a TTL cache. Will be created on first run.
# CACHE_PATH=.cache/movie_metadata.sqlite
# CACHE_TTL_SEARCH_SECONDS=3600
# CACHE_TTL_DETAILS_SECONDS=86400

# --- MCP transport --------------------------------------------------

# Bearer token required when exposing the server over HTTP+SSE. Generate with
# `python -c 'import secrets; print(secrets.token_urlsafe(32))'`.
# Leave empty when running over stdio (local / Claude Desktop / Inspector).
MCP_AUTH_TOKEN=

# Transport to use. One of: stdio | sse | streamable-http. Default: stdio.
# MCP_TRANSPORT=stdio
